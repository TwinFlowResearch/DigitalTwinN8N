    {
      "parameters": {
        "jsCode": "const ctx = $('Enrich-Context').first().json;\nif (!ctx) throw new Error(\"Enrich-Context hat nichts zurückgegeben.\");\n\nconst trace = ctx.full_trace || [];\nlet containerId = ctx.disruption?.container_id ?? null;\n\n// 1. Fallback für die Container-ID\nif (!containerId && trace.length > 0) {\n  for (const event of trace) {\n    const objects = event.objects || [];\n    if (Array.isArray(objects)) {\n      const found = objects.find(o => o.object_type === 'Container');\n      if (found) { containerId = found.object_id; break; }\n    }\n    if (typeof objects === 'string') {\n      const match = objects.match(/Container:([^\\s,]+)/);\n      if (match) { containerId = match[1]; break; }\n    }\n  }\n}\n\n// 2. Disruption-Type Mapping\nlet userDisruptionType = $('Merge-Inputs').first().json.body.disruption_type;\nif (userDisruptionType) {\n  userDisruptionType = userDisruptionType.toLowerCase().trim();\n}\nconst resolvedType = userDisruptionType || ctx.disruption_type;\n\n// 3. WICHTIG: Stufe aus dem Webhook-Body auslesen (Default: 4)\nconst stage = $('Merge-Inputs').first().json.body?.experiment_stage ?? 4;\n\nreturn [{ json: {\n  body: {\n    order_id:   ctx.order_id,\n    disruption: ctx.disruption ? { \n      ...ctx.disruption, \n      type: resolvedType, \n      container_id: containerId \n    } : null\n  },\n  source:                 $('Merge-Inputs').first().json.source || \"webhook\",\n  has_disruption:         ctx.has_disruption,\n  depart_time:            ctx.disruption?.expected_miss_time ?? null,\n  action_catalog:         ctx.action_catalog,\n  disruption_description: ctx.disruption_description,\n  search_object_type:     ctx.search_object_type,\n  full_trace:             ctx.full_trace,\n  // ↓ DAS MUSS HIER STEHEN: Damit wird die Stufe an den Switch-Node weitergegeben!\n  experiment_stage:       stage \n}}];"
      },
