        "jsonBody": "={\n  \"order_id\": \"{{ $('Merge-Inputs').first().json.body.order_id }}\",\n  \"trigger_event_id\": \"{{ $('Merge-Context').first().json.body.disruption?.event_id ?? null }}\",\n  \"confidence_score\": {{ $json.confidence_score || 0 }},\n  \"chain_of_thought\": {{ JSON.stringify($json.chain_of_thought || \"kein chain_of_thought\") }},\n  \"test_id\": \"{{ $('Merge-Inputs').first().json.body.test_id || '' }}\",\n  \"experiment_stage\": {{ $('Merge-Inputs').first().json.body.experiment_stage || 4 }},\n  \"disruption_type\": \"{{ $('Merge-Inputs').first().json.body.disruption_type || $('Merge-Context').first().json.body.disruption?.type || 'unknown' }}\",\n  \"llm_model\": \"OpenRouter\",\n  \"compliance_approved\": {{ $json.compliance_approved ?? true }},\n  \"compliance_rejection_count\": {{ $json.compliance_rejection_count || 0 }},\n  \"hitl_required\": {{ $json.confidence_score < 0.70 }},\n  \"events\": {{ JSON.stringify(($json.events || []).map((ev, index) => ({\n  ...ev,\n  event_type: ev.event_type || ev.type || \"unknown_action\",\n  event_timestamp: ev.event_timestamp || $('Merge-Context').first().json.body.disruption?.event_time || \"2023-06-01 09:00:00\",\n  is_new_event: ev.is_new_event ?? true,\n  shadow_id: ev.shadow_id || (\"sh_\" + $('Merge-Inputs').first().json.body.order_id + \"_healed_\" + index + \"_\" + Date.now())\n}))) }}\n}",
