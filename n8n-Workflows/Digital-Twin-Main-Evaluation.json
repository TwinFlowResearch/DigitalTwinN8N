        "jsCode": "return [{ json: {\n  order_id:                   $('Merge-Inputs').first().json.body.order_id,\n  chain_of_thought:           \"Eskaliert: Compliance-Agent hat nach maximalen Versuchen nicht genehmigt.\",\n  confidence_score:           0.0,\n  events:                     [],\n  compliance_approved:        false,\n  compliance_rejection_count: 3,\n  hitl_required:              true\n}}];"
