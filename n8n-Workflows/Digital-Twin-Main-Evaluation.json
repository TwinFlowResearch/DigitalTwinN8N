        "jsCode": "const input = ($json.chatInput || \"\").trim();\nconst parts = input.split(/\\s+/);\n\nconst order_id = parts[0] || \"co1\";\nlet disruption_type = parts[1] || null;\n\n// Übersetzungstabelle: Macht aus Chat-Eingaben exakte Backend-Schlüssel\nconst mapping = {\n  \"truck\": \"truck_breakdown\",\n  \"stapler\": \"forklift_breakdown\",\n  \"schiff\": \"no_vehicle\",\n  \"wetter\": \"weather_delay\",\n  \"container\": \"container_damage\"\n};\n\nif (disruption_type) {\n  disruption_type = mapping[disruption_type.toLowerCase().trim()] || disruption_type;\n}\n\nreturn [{\n  json: {\n    body: {\n      order_id: order_id,\n      disruption_type: disruption_type\n    },\n    source: \"chat\"\n  }\n}];"
      },
