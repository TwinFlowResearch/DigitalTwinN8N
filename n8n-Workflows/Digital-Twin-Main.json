      "parameters": {
        "jsCode": "// Der Nutzer tippt nur noch die Order-ID.\n// Alles andere (Störungstyp, Objekt-ID, Deadline) holt das Backend\n// automatisch aus der echten Datenbank.\n//\n// Beispiele die jetzt funktionieren:\n//   \"co1\"                    -> zufälliger Störungstyp wird gewählt\n//   \"co1 truck_breakdown\"    -> spezifischer Störungstyp wird erzwungen\n//   \"co5\"                    -> andere Bestellung, alles automatisch\n\nconst input  = ($json.chatInput || \"\").trim();\nconst parts  = input.split(/\\s+/);\n\nconst order_id        = parts[0] || \"co1\";\nconst disruption_type = parts[1] || null;  // null = Backend wählt selbst\n\nreturn [{ json: {\n  body: {\n    order_id:       order_id,\n    disruption_type: disruption_type\n  },\n  source: \"chat\"\n}}];"
