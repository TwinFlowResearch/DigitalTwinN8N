    {
      "parameters": {
        "jsCode": "const ctx = $('Enrich-Context').first().json;\n\n// Prüfen ob das Backend eine Antwort geliefert hat\nif (!ctx) {\n  throw new Error(\"Enrich-Context hat kein Ergebnis zurückgegeben.\");\n}\n\n// FALL A: Es liegt KEINE Störung vor (Normalbetrieb)\nif (ctx.has_disruption === false) {\n  return [{ json: {\n    body: {\n      order_id:  ctx.order_id,\n      disruption: null\n    },\n    has_disruption:          false,\n    source:                  $('Merge-Inputs').first().json.source || \"webhook\",\n    full_trace:              ctx.full_trace,\n    depart_time:             null,\n    action_catalog:          [],\n    disruption_description:  \"Normalbetrieb — Keine Störungen gemeldet.\",\n    search_object_type:      null\n  }}];\n}\n\n// FALL B: Es liegt eine Störung vor (Prüfung wie bisher)\nif (!ctx.disruption) {\n  throw new Error(\n    \"Enrich-Context hat keine Störungsdaten zurückgegeben, obwohl eine Störung vorliegt.\"\n  );\n}\n\nreturn [{ json: {\n  body: {\n    order_id:  ctx.order_id,\n    disruption: ctx.disruption\n  },\n  has_disruption:          true,\n  source:                  $('Merge-Inputs').first().json.source || \"webhook\",\n  depart_time:             ctx.disruption.expected_miss_time,\n  action_catalog:          ctx.action_catalog,\n  disruption_description:  ctx.disruption_description,\n  search_object_type:      ctx.search_object_type,\n  full_trace:              ctx.full_trace\n}}];"
      },
